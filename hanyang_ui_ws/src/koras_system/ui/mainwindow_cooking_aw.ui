     <property name="styleSheet">
      <string notr="true">QPushButton {
    font-size: 18px;
    font-weight: bold;
    color: #FFFFFF; /* 텍스트 흰색 */
    border: 3px solid #E74C3C; /* 빨간 테두리 */
    border-radius: 8px; /* 부드러운 모서리 */
    background-color: qlineargradient(
        spread: pad, x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #FF6F61, stop: 1 #FF4500
    ); /* 그라데이션 효과 */
    padding: 10px;
}

QPushButton:hover {
    background-color: qlineargradient(
        spread: pad, x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #E57373, stop: 1 #F44336
    ); /* 호버 효과 */
}

QPushButton:pressed {
    background-color: #C0392B; /* 눌렀을 때 짙은 빨간색 */
    border: 2px solid #922B21; /* 테두리 강조 */
}
</string>
