     </property>
     <property name="styleSheet">
      <string notr="true">QPushButton#pushButton_stop {
    font-size: 18px;
    font-weight: bold;
    color: #FFFFFF;                 /* 흰색 텍스트 */
    border: 2px solid #8B0000;      /* DarkRed 테두리 */
    border-radius: 12px;
    background-color: qlineargradient(
        spread: pad, x1: 0, y1: 0, x2: 1, y2: 1,
        /* 더 붉은 빨간색 그라데이션: 위쪽은 선명한 빨강, 아래는 조금 더 어두운 빨강 */
        stop: 0 #FF0000,
        stop: 1 #B22222
    );
    padding: 15px;
}

QPushButton#pushButton_stop:hover {
    /* 호버 시 더 밝은 레드 */
    background-color: #FF3030;
}

QPushButton#pushButton_stop:pressed {
    /* 눌렀을 때 (Pressed) 진한 빨강 + 테두리 강조 */
    background-color: #8B0000;
    border: 3px solid #800000;
}


</string>
     </property>
