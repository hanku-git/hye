     <property name="styleSheet">
      <string notr="true">QPushButton#pushButton_start {
    font-size: 18px;
    font-weight: bold;
    color: #FFFFFF;
    /* border: 2px solid #E74C3C; (빨간색 테두리였던 부분을 초록 계열로 변경) */
    border: 2px solid #2E7D32; 
    border-radius: 12px;
    background-color: qlineargradient(
        spread: pad, x1: 0, y1: 0, x2: 1, y2: 1,
        /* 기존 #FF6F61 ~ #FF4500 대신 녹색 계열로 변경 */
        stop: 0 #7ED957, 
        stop: 1 #4CAF50
    );
    padding: 15px;
}

QPushButton#pushButton_start:hover {
    /* 빨간색 호버색 대신 연한 초록색 계열로 변경 */
    background-color: #81C784; 
}

QPushButton#pushButton_start:pressed {
    /* 눌렀을 때 진한 초록색 계열 */
    background-color: #388E3C; 
    /* 테두리도 더 진하게 */
    border: 3px solid #1B5E20; 
}
</string>
     </property>
     <property name="text">
      <string>Start</string>
     </property>
    </widget>
    <widget class="QPushButton" name="pushButton_stop">
     <property name="geometry">
      <rect>
       <x>230</x>
       <y>150</y>
       <width>241</width>
       <height>51</height>
      </rect>
     </property>
     <property name="font">
      <font>
       <family>Serif</family>
