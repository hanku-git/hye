       <string notr="true">QPushButton {
    background-color: rgb(255, 163, 72);
    border-radius: 40px;
    color: black;
    font-weight: bold;
}

/* 체크 상태 (눌려진 상태일 때 초록색 유지) */
QPushButton:checked {
    background-color: rgb(143, 240, 164); /* 초록색 */
}
</string>
