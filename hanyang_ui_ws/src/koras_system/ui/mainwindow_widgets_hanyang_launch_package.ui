  <property name="styleSheet">
   <string>
QMainWindow {
    background: white;
    color: #2d3748;
    font-family: 'Segoe UI', 'Noto Sans KR', sans-serif;
}

QTabWidget::pane {
    border: 2px solid #e2e8f0;
    background: white;
    border-radius: 12px;
    margin-top: 8px;
}

QTabWidget::tab-bar {
    alignment: center;
}

QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #f7fafc, stop:1 #edf2f7);
    color: #4a5568;
    padding: 12px 24px;
    margin-right: 4px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: bold;
    font-size: 14px;
    min-width: 120px;
    border: 1px solid #e2e8f0;
}

QTabBar::tab:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #667eea, stop:1 #764ba2);
    color: white;
    border-bottom: 3px solid #667eea;
}

QTabBar::tab:hover:!selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #5a67d8, stop:1 #4c51bf);
    color: white;
}

QWidget {
    background: transparent;
    color: #2d3748;
    font-family: 'Segoe UI', 'Noto Sans KR', sans-serif;
}

QTextEdit {
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    color: #2d3748;
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    font-size: 14px;
    padding: 8px;
    selection-background-color: #667eea;
}

QTextEdit:focus {
    border: 2px solid #667eea;
    
}

QComboBox {
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    color: #2d3748;
    font-size: 13px;
    padding: 8px 12px;
    min-height: 20px;
}

QComboBox:hover {
    border: 2px solid #667eea;
    background: #f7fafc;
}

QComboBox:focus {
    border: 2px solid #667eea;
    
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #4a5568;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    color: #2d3748;
    selection-background-color: #667eea;
    outline: none;
}

QLabel {
    color: #2d3748;
    font-weight: bold;
    font-size: 13px;
}

QLabel[label_makeToolWeightStatus], QLabel[label_setToolWeightStatus], QLabel[label_addTcpPresetStatus] {
    background: qradialgradient(cx:0.5, cy:0.5, radius:0.5, 
        stop:0 #ff6b6b, stop:1 #ee5a52);
    border: 2px solid #ff4757;
    border-radius: 10px;
    
}

QStatusBar {
    background: white;
    color: #2d3748;
    border-top: 1px solid #e2e8f0;
}
