Panels:
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: PointCloud2
  - Class: rviz_common/Displays
    Help Height: 75
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /PointCloud21
        - /Axes1
        - /OccupancyGrid1
        - /OccupancyGrid2
        - /Pose1
      Splitter Ratio: 0.513711154
    Tree Height: 846
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: false
      Line Style:
        Line Width: 0.0299999993
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 10
      Reference Frame: <Fixed Frame>
      Value: false
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 255; 255
      Color Transformer: RGB8
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: PointCloud2
      Position Transformer: XYZ
      Queue Size: 10
      Selectable: true
      Size (Pixels): 3
      Size (m): 2
      Style: Spheres
      Topic: /ku_scan/cloud/xyzrgba/simulation
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    - Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 100
      Name: Axes
      Radius: 2.5
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: octomap_rviz_plugin/OccupancyGrid
      Enabled: true
      Max. Height Display: 3.40282347e+38
      Max. Octree Depth: 16
      Min. Height Display: -3.40282347e+38
      Name: OccupancyGrid
      Octomap Topic: /ku_scan/octomap/simulation
      Queue Size: 5
      Value: true
      Voxel Alpha: 0.100000001
      Voxel Coloring: Cell Probability
      Voxel Rendering: Occupied Voxels
    - Class: octomap_rviz_plugin/OccupancyGrid
      Enabled: true
      Max. Height Display: 3.40282347e+38
      Max. Octree Depth: 16
      Min. Height Display: -3.40282347e+38
      Name: OccupancyGrid
      Octomap Topic: /ku_scan/octomap/simulation_objects
      Queue Size: 5
      Value: true
      Voxel Alpha: 1
      Voxel Coloring: Cell Probability
      Voxel Rendering: Occupied Voxels
    - Alpha: 1
      Axes Length: 125
      Axes Radius: 10
      Class: rviz_default_plugins/Pose
      Color: 255; 25; 0
      Enabled: true
      Head Length: 20
      Head Radius: 20
      Name: Pose
      Shaft Length: 150
      Shaft Radius: 5
      Shape: Axes
      Topic: /ku_scan/frame/simulation_objects
      Unreliable: false
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: ku_matching_frame
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
    - Class: rviz_default_plugins/SetInitialPose
      Topic: /initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 599.444946
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.0599999987
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: -77.1266174
        Y: -216.498352
        Z: 1.48652601
      Focal Shape Fixed Size: false
      Focal Shape Size: 0.0500000007
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.00999999978
      Pitch: 0.114797875
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 1.33176625
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 1056
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
